# Redis must point to the Linux control plane and remain reachable from Windows executors.
AUTOIN_ENV=development
AUTOIN_LOG_LEVEL=INFO
AUTOIN_REDIS_HOST=redis.internal.example.com
AUTOIN_REDIS_PORT=6379
AUTOIN_REDIS_PASSWORD=replace-me
AUTOIN_REDIS_DB=0
AUTOIN_REDIS_STREAM_KEY=autoin:stream:events
AUTOIN_REDIS_TASK_STREAM_KEY=autoin:stream:tasks
AUTOIN_REDIS_DEAD_LETTER_STREAM_KEY=autoin:stream:dead-letter
AUTOIN_REDIS_PUBSUB_CHANNEL=autoin:channel:events
AUTOIN_REDIS_CONSUMER_GROUP=autoin:group:coordinator
AUTOIN_UI_LOCK_KEY=autoin:lock:ui
AUTOIN_UI_LOCK_TTL_MS=15000
AUTOIN_UI_LOCK_RETRY_DELAY_MS=250
AUTOIN_UI_LOCK_RETRY_LIMIT=20
